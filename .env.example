# ─────────────────────────────────────────────────────────────────────────────
# Upwork Official API credentials
# Get these from the Upwork Developer Portal: https://www.upwork.com/developer/
# 1. Sign in to Upwork → open the developer portal → "Create a new app / API project"
# 2. Set the OAuth2 Redirect URI to:  http://localhost:3000/api/auth/callback
# 3. Copy the generated Client ID and Client Secret below.
# ─────────────────────────────────────────────────────────────────────────────

UPWORK_CLIENT_ID=
UPWORK_CLIENT_SECRET=

# Must EXACTLY match the redirect URI registered in your Upwork app.
UPWORK_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Optional: Upwork organization / tenant id, required by some GraphQL queries.
# Leave empty unless your account has multiple organizations.
UPWORK_TENANT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# App behaviour
# ─────────────────────────────────────────────────────────────────────────────

# DEMO mode: when "true", the app serves realistic dummy jobs and never calls
# the real Upwork API. If credentials above are empty, DEMO mode turns on
# automatically. Set to "false" to force real API usage.
UPWORK_DEMO_MODE=false

# Secret used to encrypt the OAuth token cookie. Generate a random 32+ char string.
# e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=change-me-to-a-long-random-string
